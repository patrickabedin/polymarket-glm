# ═══════════════════════════════════════════════════════════════════════════════
#  POLYMARKET WHALE COPY TRADER — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Polymarket Wallet (for auto-trading) ───────────────────────────────────────
# Your Polygon wallet private key (0x-prefixed). Required for auto-trade mode.
# Leave empty to run in alert-only mode. Do NOT use a zero key.
POLY_PRIVATE_KEY=

# Funder address (your wallet's public address). Required for auto-trade mode.
POLY_FUNDER_ADDRESS=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the token.
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (message @userinfobot to get yours).
TELEGRAM_CHAT_ID=

# ── Moralis (optional, for on-chain wallet profiling) ──────────────────────────
MORALIS_API_KEY=
